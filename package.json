{
  "name": "echodesk",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/src/index.ts",
    "build": "vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx scripts/seed.ts",
    "prepare": "husky",
    "lint": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{ts,tsx}": "tsc --noEmit",
    "*.{ts,tsx,js,jsx}": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@prisma/client": "^6.6.0",
    "@sentry/node": "^10.57.0",
    "@sentry/react": "^8.55.0",
    "@tanstack/react-query": "^5.101.0",
    "clsx": "2.1.1",
    "hono": "^4.7.0",
    "ioredis": "^5.6.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^7.17.0",
    "tailwind-merge": "3.4.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "4.1.17",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "bcryptjs": "^2.4.3",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prisma": "^6.6.0",
    "tailwindcss": "4.1.17",
    "tsx": "^4.19.0",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vite-plugin-singlefile": "2.3.0",
    "vitest": "^3.1.0"
  }
}
